# Copy this file to .env and fill in real values before running docker compose up

GEMINI_API_KEY=your-gemini-api-key-here       # optional — only needed if LLM_PROVIDER=GEMINI
GROQ_API_KEY=your-groq-api-key-here           # get a free key at https://console.groq.com
LLM_PROVIDER=GROQ                             # GROQ (default) or GEMINI
GROQ_MODEL=llama-3.3-70b-versatile            # optional — override the default Groq model

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
